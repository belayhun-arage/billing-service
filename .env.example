DATABASE_URL=
STRIPE_SECRET_KEY=sk_test_your_key_here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourapp.com

# HTTP / gRPC ports (optional, defaults shown)
HTTP_PORT=8080
GRPC_PORT=9090

# Rate limiting (per API key)
RATE_LIMIT_RPS=10      # tokens per second (default: 10 = 600 req/min)
RATE_LIMIT_BURST=20    # max burst size

# Kafka — leave KAFKA_BROKERS empty to disable outbox publishing (events stay in DB)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=billing-events

# SMTP — leave SMTP_HOST empty to disable email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your@gmail.com